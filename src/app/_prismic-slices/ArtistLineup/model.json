{
  "id": "artist_lineup",
  "type": "SharedSlice",
  "name": "ArtistLineup",
  "description": "Manually-ordered grid of artist cards. Empty entries render as blurred placeholders (e.g. for unannounced acts).",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "title": {
          "type": "Text",
          "config": {
            "label": "Title",
            "placeholder": "(optional)"
          }
        },
        "title_sl": {
          "type": "Text",
          "config": {
            "label": "Title (SL)",
            "placeholder": "(optional)"
          }
        },
        "description": {
          "type": "Text",
          "config": {
            "label": "Description",
            "placeholder": "(optional)"
          }
        },
        "description_sl": {
          "type": "Text",
          "config": {
            "label": "Description (SL)",
            "placeholder": "(optional)"
          }
        },
        "render_frame": {
          "type": "Boolean",
          "config": {
            "label": "Render frame",
            "placeholder_false": "No background",
            "placeholder_true": "With background",
            "default_value": false
          }
        },
        "show_names": {
          "type": "Boolean",
          "config": {
            "label": "Show artist names",
            "placeholder_false": "Hide names",
            "placeholder_true": "Show names",
            "default_value": true
          }
        },
        "link_override": {
          "type": "Link",
          "config": {
            "label": "Link override (applied to all cards in this slice)",
            "allowTargetBlank": true
          }
        },
        "artists": {
          "type": "Group",
          "config": {
            "label": "Artists",
            "repeat": true,
            "fields": {
              "artist": {
                "type": "Link",
                "config": {
                  "label": "Artist (leave empty for blurred placeholder)",
                  "select": "document",
                  "customtypes": [
                    "artist"
                  ]
                }
              },
              "name_override": {
                "type": "Text",
                "config": {
                  "label": "Name override (optional)",
                  "placeholder": ""
                }
              },
              "name_override_sl": {
                "type": "Text",
                "config": {
                  "label": "Name override (optional) (SL)",
                  "placeholder": ""
                }
              },
              "image_override": {
                "type": "Image",
                "config": {
                  "label": "Image override (optional)",
                  "constraint": {},
                  "thumbnails": []
                }
              }
            }
          }
        }
      },
      "items": {}
    }
  ]
}
